{
  "name": "@coaction/zustand",
  "version": "3.0.0",
  "description": "A Coaction integration tool for Zustand",
  "keywords": [
    "coaction",
    "hook",
    "state",
    "zustand"
  ],
  "homepage": "https://github.com/coactionjs/coaction/tree/main/packages/coaction-zustand#readme",
  "bugs": {
    "url": "https://github.com/coactionjs/coaction/issues"
  },
  "license": "MIT",
  "author": "unadlib",
  "repository": {
    "type": "git",
    "url": "https://github.com/coactionjs/coaction.git",
    "directory": "packages/coaction-zustand"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rm -rf dist",
    "test": "vitest run test",
    "build": "node ../../scripts/build-package.mjs",
    "dev": "node ../../scripts/build-package.mjs --watch"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/use-sync-external-store": "^1.5.0",
    "coaction": "workspace:*",
    "data-transport": "^5.0.3",
    "jsdom": "^28.1.0",
    "jsdom-global": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "coaction": "^3.0.0",
    "zustand": "^4.0.0 || ^5.0.0"
  },
  "authors": [
    "Michael Lin <unadlib@gmail.com> (https://github.com/unadlib)"
  ]
}
