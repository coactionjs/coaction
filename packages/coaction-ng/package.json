{
  "name": "@coaction/ng",
  "version": "2.0.0",
  "description": "A Coaction integration tool for Angular",
  "keywords": [
    "angular",
    "coaction",
    "signals",
    "state"
  ],
  "homepage": "https://github.com/coactionjs/coaction/tree/main/packages/coaction-ng#readme",
  "bugs": {
    "url": "https://github.com/coactionjs/coaction/issues"
  },
  "license": "MIT",
  "author": "unadlib",
  "repository": {
    "type": "git",
    "url": "https://github.com/coactionjs/coaction.git",
    "directory": "packages/coaction-ng"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rm -rf dist",
    "test": "vitest run test",
    "build": "node ../../scripts/build-package.mjs",
    "dev": "node ../../scripts/build-package.mjs --watch"
  },
  "devDependencies": {
    "@angular/core": "^22.0.2",
    "coaction": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": "^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0 || ^21.0.0 || ^22.0.0",
    "coaction": "^2.0.0"
  },
  "authors": [
    "Michael Lin <unadlib@gmail.com> (https://github.com/unadlib)"
  ]
}
