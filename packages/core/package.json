{
  "name": "coaction",
  "version": "3.0.0",
  "description": "A sleek JavaScript library designed for high-performance and multithreading web apps.",
  "keywords": [
    "coaction"
  ],
  "homepage": "https://github.com/coactionjs/coaction/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/coactionjs/coaction/issues"
  },
  "license": "MIT",
  "author": "unadlib",
  "repository": {
    "type": "git",
    "url": "https://github.com/coactionjs/coaction.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "adapter.d.ts",
    "adapter.js",
    "local.d.ts",
    "local.js",
    "shared.d.ts",
    "shared.js"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.mjs"
    },
    "./local": {
      "import": {
        "types": "./dist/local.d.mts",
        "default": "./dist/local.mjs"
      },
      "require": {
        "types": "./dist/local.d.ts",
        "default": "./dist/local.js"
      },
      "default": "./dist/local.mjs"
    },
    "./shared": {
      "import": {
        "types": "./dist/shared.d.mts",
        "default": "./dist/shared.mjs"
      },
      "require": {
        "types": "./dist/shared.d.ts",
        "default": "./dist/shared.js"
      },
      "default": "./dist/shared.mjs"
    },
    "./adapter": {
      "import": {
        "types": "./dist/adapter.d.mts",
        "default": "./dist/adapter.mjs"
      },
      "require": {
        "types": "./dist/adapter.d.ts",
        "default": "./dist/adapter.js"
      },
      "default": "./dist/adapter.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rm -rf dist",
    "test": "vitest run test",
    "build": "node ../../scripts/build-package.mjs",
    "dev": "node ../../scripts/build-package.mjs --watch"
  },
  "dependencies": {
    "alien-signals": "^3.1.2",
    "data-transport": "^5.0.3",
    "mutative": "^1.3.0"
  },
  "authors": [
    "Michael Lin <unadlib@gmail.com> (https://github.com/unadlib)"
  ]
}
