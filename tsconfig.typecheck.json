{
  "extends": "./tsconfig.json",
  "include": [
    "global.d.ts",
    "vitest.setup.js",
    "*.config.*",
    "scripts/**/*.ts",
    "packages/*/index.ts",
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "packages/*/test/**/*.tsx"
  ],
  "exclude": [
    "examples",
    "templates",
    "node_modules",
    "coverage",
    ".turbo",
    "packages/**/dist/**",
    "packages/**/.turbo/**",
    "packages/**/benchmark/**"
  ]
}
